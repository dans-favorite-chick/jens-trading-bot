# Claude Code: ignore worktree/cache/session state, but COMMIT skills/agents/commands/settings
# (the audit on 2026-04-25 flagged that the broad `.claude/` rule was blocking
# future Phoenix-specific skills under .claude/skills/ from ever committing.)
.claude/worktrees/
.claude/cache/
.claude/file-history/
.claude/session-env/
.claude/sessions/
.claude/shell-snapshots/
.claude/telemetry/
.claude/projects/
.claude/ide/
.claude/paste-cache/
.claude/plans/
.claude/scheduled-tasks/
.claude/backups/
.claude/.credentials.json
.claude/history.jsonl
# Tracked: .claude/settings.json, .claude/skills/, .claude/agents/, .claude/commands/

# Scratch directories (see SCRATCH_DIRS.md)
Phoenix Rising Project/

# Runtime data — keep folder shape only, ignore contents
data/*.json
data/knowledge_vectors/
data/trade_vectors/
# Pre-emptive: cover future binary formats anywhere under data/
data/**/*.sqlite
data/**/*.db
data/**/*.parquet
!data/.gitkeep

# === added 2026-04-25 — cruft that should never be tracked ===
.venv-ml/
bin/
models/
data/cache/
data/regime_history.jsonl
heartbeat/
*.pyc
*.pyc.*
__pycache__/
council/
base_bot_check.pyc.*

# Broad ignores for noisy auto-generated content WITH targeted allowlists
# below for the parts of these trees that ARE source-controlled.
.claude/
out/
phoenix_bot/

# === 2026-04-25 allowlists — keep these committed despite broad ignores above ===
# phoenix_bot/orchestrator/ holds the OIFSink Protocol — required when
# PHOENIX_RISK_GATE=1 is enabled. base_bot.py imports from here.
!phoenix_bot/
!phoenix_bot/orchestrator/
!phoenix_bot/orchestrator/**

# .claude/commands/ — slash command contracts (phoenix-morning-ritual etc.)
# .claude/skills/   — project-specific Phoenix skills (none yet, future-ready)
# .claude/agents/   — project-specific agent prompts (future-ready)
# .claude/settings.json — project-scoped Claude Code settings (enabledPlugins)
!.claude/
!.claude/commands/
!.claude/commands/**
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
!.claude/settings.json

# out/baselines/ — pre-computed grader baselines (P5 squeeze_baseline.json etc.)
# Other out/ contents (grades, morning_ritual, debrief, weekly_evolution, bench,
# ad-hoc diagnostic JSONs) stay regenerable + ignored.
!out/
out/*
!out/baselines/
!out/baselines/**

# === 2026-04-25 re-ignores: __pycache__ + .pyc inside allowlisted dirs ===
# The allowlist patterns above use `**` and would otherwise un-ignore stale
# bytecode caches. Re-ignore here so they DON'T sneak into commits.
phoenix_bot/**/__pycache__/
phoenix_bot/**/*.pyc
phoenix_bot/**/*.pyo
.claude/**/__pycache__/
.claude/**/*.pyc

# === 2026-05-18 overnight session — historical data + backtest artifacts ===
# Large CSVs are regenerable from tools/decompress_databento.py +
# tools/databento_to_phoenix_v2.py. Keep the repo lean.
# To reproduce locally:
#   1. Re-pull from Databento (their dashboard has download history)
#   2. python tools/decompress_databento.py
#   3. python tools/databento_to_phoenix_v2.py
data/historical/glbx-mdp3-*.csv
data/historical/glbx-mdp3-*.csv.zst
data/historical/*_databento.csv

# Backtest CSV outputs. The generator .py scripts are tracked; the CSV
# results are regenerable and noisy in diffs.
backtest_results/*.csv

# Pre-existing untracked stragglers from earlier sessions (.Last tick files,
# legacy backtest outputs). Not deleting in case they're useful for
# investigation, but not committing.
data/historical/MNQ 06-26.Last
data/historical/MES 06-26.Last
data/historical/MNQ 06-26.Last.txt
data/historical/backtest_results.csv
data/historical/backtest_summary.txt
data/historical/es_nq_strategy_summary_v2.csv
data/historical/es_nq_strategy_trades_v2.csv
data/historical/phase12_gridsearch.csv
data/historical/phase12_validation.csv

# Stray .env backup from a prior gemini-key rotation (must never track).
.env.backup_*

# === 2026-05-19 — TBBO directory ===
# Raw DBN dumps from Databento are ~1 GB; never track.  Generated CSVs
# from the same dataset (footprints, etc.) are regenerable so ignore them.
# The README.md and .metadata.json files in this dir ARE tracked because
# they document what the regenerable binaries should look like.
data/historical/databento_tbbo/*.dbn.zst
data/historical/databento_tbbo/*.csv

# === 2026-05-20 — single-instance PID lock files (B-004) ===
# run/<bot>.pid files are runtime state from core/single_instance.py;
# they reflect the live PID holding the lock and are recreated on bot
# start. Tracking them would cause merge conflicts every restart.
run/

# === 2026-05-21 — tier_3000 equity state ===
# data/equity_state.json tracks live equity, ATH, consecutive losses,
# and session-start equity for the tier_3000 compounding sizer. Per-
# operator runtime state, not source.
data/equity_state.json
_commit_msg.tmp
